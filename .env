# Puerto del servidor API
PORT=3000

# Conexión a PostgreSQL (pgAdmin usa el mismo servidor)
# Formato: postgresql://USUARIO:CONTRASEÑA@localhost:5432/NOMBRE_BD
# Reemplaza USUARIO (ej: postgres) y CONTRASEÑA por los de tu instalación
DATABASE_URL=postgresql://postgres:1234@localhost:5432/farmago

# Solo true si usas un servidor remoto con SSL (ej: cloud)
DATABASE_SSL=false
